# Local development example. Do not put real secrets in this file.

# PostgreSQL connection string.
# Local example:
# DATABASE_URL=postgres://cryptopulse_user:change_me@localhost:5432/cryptopulse?sslmode=disable
# Production example should usually use sslmode=require.
DATABASE_URL=postgres://cryptopulse_user:change_me@localhost:5432/cryptopulse?sslmode=disable

# HTTP port used by the application. Koyeb injects PORT automatically.
PORT=8080

# Telegram bot token from BotFather.
TELEGRAM_APITOKEN=123456789:replace_with_your_telegram_bot_token

# Secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token.
WEBHOOK_SECRET_TOKEN=replace_with_a_long_random_webhook_secret

# Bearer token required by /cron and /metrics.
CRON_SECRET=replace_with_a_long_random_cron_secret
